# 📎 WebsiteGenerator Core Environment Variables

# The server port (defaults to 3000)
PORT=3000

# Shared internal API key for backend routes
INTERNAL_API_KEY=

# Comma separated list of allowed CORS origins
ALLOWED_ORIGINS=

# The selected AI LLM provider: groq | openrouter | ollama (defaults to groq)
AI_PROVIDER=groq

# 1. Groq Configuration
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# 2. OpenRouter Configuration
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3-70b-instruct

# 3. Ollama Configuration (Local Models)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# 4. Database Connection URL (Needed for generated Full-Stack CRUD backends)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/websiteGenerator_generated
